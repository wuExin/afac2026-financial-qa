root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4

[*.{md,yaml,yml,json,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2

[*.{bat,cmd,ps1}]
end_of_line = crlf

[.{editorconfig,gitignore,gitattributes,env*}]
indent_size = 2